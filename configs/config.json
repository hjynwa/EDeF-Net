{
    "name": "EDeF-Net",
    "n_gpu": 1,
    "arch": {
        "type": "EDeFT3D",
        "args": {
            "t_embed_dim": 48,
            "t_depths": 4,
            "t_num_heads": 6,
            "t_dim_head": 128,
            "in_chans": 8,
            "window_size": 4,
            "patch_size": 1,
            "ape": false,
            "embed_dim": 48,
            "depths": [
                4,
                4,
                4,
                4
            ],
            "num_heads": [
                4,
                4,
                4,
                4
            ],
            "mlp_ratio": 2,
            "ms": false
        }
    },
    "data_loader": {
        "type": "EvstackTrainDataLoader",
        "args": {
            "data_dir": "./dataset/stack_8c_1w_dataset",
            "batch_size": 2,
            "shuffle": true,
            "validation_split": 0,
            "training": true,
            "num_workers": 16,
            "transform": 0
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.0001,
            "betas": [
                0.5,
                0.999
            ],
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": {
        "type": [
            "l1_loss",
            "num_ev_loss"
        ],
        "args": {
            "l1_loss_lambda": 1.0,
            "num_ev_loss_lambda": 1e-07
        }
    },
    "metrics": [
        "mse"
    ],
    "lr_scheduler": {
        "type": "LambdaLR",
        "args": {
            "decay_starts": 50
        }
    },
    "trainer": {
        "epochs": 60,
        "save_dir": "saved/",
        "save_period": 5,
        "log_step": 10,
        "verbosity": 2,
        "monitor": "min val_loss",
        "early_stop": 10,
        "tensorboard": true
    }
}